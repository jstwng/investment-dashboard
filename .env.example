VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── SnapTrade (set these as Supabase Edge Function secrets, NOT as VITE_ env vars) ──
# Dashboard: https://supabase.com/dashboard/project/<ref>/settings/edge-functions
# SNAPTRADE_CLIENT_ID=<from https://dashboard.snaptrade.com>
# SNAPTRADE_CONSUMER_KEY=<from https://dashboard.snaptrade.com — keep secret>
# SNAPTRADE_REDIRECT_URL=<your app URL + ?snaptradeSuccess=1, e.g. http://localhost:5173/?snaptradeSuccess=1>
